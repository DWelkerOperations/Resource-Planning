{
  "name": "airline-catering-dispatch-prototype",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint .",
    "security:audit": "pnpm audit --prod --audit-level high --ignore GHSA-4r6h-8v6p-xvw6 --ignore GHSA-5pgg-2g8v-p4x9",
    "typecheck": "tsc",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "tsc -p tsconfig.test.json && node -e \"require('node:fs').writeFileSync('.test-build/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\" && node --test .test-build/tests/*.test.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^4.5.5"
  }
}
